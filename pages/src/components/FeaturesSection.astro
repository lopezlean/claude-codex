---
import { site } from "../data/site";
---

<section id="features" class="shell section">
  <span class="eyebrow">Core capabilities</span>
  <h2 class="section-title">A thin bridge, not a reinvention.</h2>
  <p class="section-copy">
    The wrapper stays focused on the local launch contract: authenticate once, route the right
    backend, translate the protocol boundary, and keep Claude Code pointed at the proxy.
  </p>

  <div class="grid">
    {
      site.features.map((feature, index) => (
        <article class="panel card">
          <span class="index">0{index + 1}</span>
          <h3>{feature.title}</h3>
          <p>{feature.body}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-top: 28px;
  }

  .card {
    padding: 24px;
  }

  .index {
    display: inline-block;
    margin-bottom: 28px;
    color: var(--cyan);
    font-family: var(--mono);
    font-size: 0.85rem;
  }

  h3 {
    margin: 0 0 10px;
    font-family: var(--display);
    font-size: 1.4rem;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
