---
import { site } from "../data/site";
---

<header class="nav shell">
  <a class="brand" href="/">
    <span class="brand-mark">cc</span>
    <span>{site.brand}</span>
  </a>

  <nav>
    {
      site.navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))
    }
  </nav>

  <a class="cta" href={site.repoUrl} target="_blank" rel="noreferrer">View on GitHub</a>
</header>

<style>
  .nav {
    position: sticky;
    top: 16px;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: 16px;
    padding: 14px 18px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(11, 16, 21, 0.72);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--display);
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 12px;
    color: #160f0a;
    background: linear-gradient(135deg, var(--accent), #ffb67b);
  }

  nav {
    display: flex;
    gap: 18px;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .cta {
    padding: 10px 14px;
    border-radius: 999px;
    font-size: 0.92rem;
    font-weight: 600;
    color: #130b06;
    background: linear-gradient(135deg, var(--accent-soft), #ffad7b);
  }

  @media (max-width: 840px) {
    .nav {
      flex-wrap: wrap;
      justify-content: center;
      border-radius: 24px;
    }

    nav {
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
    }
  }
</style>
